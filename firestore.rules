rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper functions ────────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    function matchDeadlinePassed(matchId) {
      let match = get(/databases/$(database)/documents/matches/$(matchId));
      // Deadline = matchDate - 10 minutes
      return request.time > match.data.matchDate - duration.value(10, 'm');
    }

    // ─── users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isAuth();
      allow create: if isOwner(uid)
        && request.resource.data.isAdmin == false
        && request.resource.data.totalPoints == 0;
      allow update: if (isOwner(uid) && !('isAdmin' in request.resource.data.diff(resource.data)))
        || isAdmin();
    }

    // ─── usernames (unique index) ─────────────────────────────────────────────
    match /usernames/{username} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ─── matches ─────────────────────────────────────────────────────────────
    match /matches/{matchId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // ─── predictions ─────────────────────────────────────────────────────────
    match /predictions/{predId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );

      // Create: must own it, match must not be closed, cannot set points
      allow create: if isOwner(request.resource.data.userId)
        && request.resource.data.matchId is string
        && request.resource.data.pointsEarned == null
        && !matchDeadlinePassed(request.resource.data.matchId);

      // Update: can change scores before deadline; admin can set points
      allow update: if (
          isOwner(resource.data.userId)
          && !matchDeadlinePassed(resource.data.matchId)
          && request.resource.data.pointsEarned == resource.data.pointsEarned
        ) || isAdmin();
    }
  }
}
